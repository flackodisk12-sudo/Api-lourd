// 🎲 RANDOM NUMBER
router.get("/random", (req, res) => {
  const min = parseInt(req.query.min) || 0;
  const max = parseInt(req.query.max) || 100;
  const count = parseInt(req.query.count) || 1;

  if (min >= max) {
    return res.status(400).json({ error: "min doit être < max" });
  }

  const generateRandom = () => Math.floor(Math.random() * (max - min + 1)) + min;
  
  logger.info(`Générant ${count} nombre(s) entre ${min} et ${max}`);

  res.json({
    range: { min, max },
    count,
    numbers: Array.from({ length: count }, generateRandom),
    single: generateRandom(),
    timestamp: new Date().toISOString()
  });
});

// 🔄 ENCODE/DECODE
router.get("/encode", (req, res) => {
  const text = req.query.text;
  const type = req.query.type || "base64";

  if (!text) {
    return res.status(400).json({ error: "Texte requis" });
  }

  try {
    let encoded, decoded;

    switch (type) {
      case "base64":
        encoded = Buffer.from(text).toString("base64");
        decoded = Buffer.from(encoded, "base64").toString("utf-8");
        break;
      case "hex":
        encoded = Buffer.from(text).toString("hex");
        decoded = Buffer.from(encoded, "hex").toString("utf-8");
        break;
      case "uri":
        encoded = encodeURIComponent(text);
        decoded = decodeURIComponent(encoded);
        break;
      default:
        return res.status(400).json({ error: "Type invalide" });
    }

    logger.success(`Encodé en ${type}`);

    res.json({
      text,
      type,
      encoded,
      decoded,
      length: text.length
    });
  } catch (e) {
    logger.error(`Encode error: ${e.message}`);
    res.status(400).json({ error: e.message });
  }
});

// 🔐 PASSWORD GENERATOR
router.get("/password-gen", (req, res) => {
  const length = Math.min(parseInt(req.query.length) || 16, 128);
  const includeSymbols = req.query.symbols !== "false";
  
  const lowercase = "abcdefghijklmnopqrstuvwxyz";
  const uppercase = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
  const numbers = "0123456789";
  const symbols = "!@#$%^&*()_+-=[]{}|;:,.<>?";

  let chars = lowercase + uppercase + numbers;
  if (includeSymbols) chars += symbols;

  const password = Array.from({ length }, () =>
    chars.charAt(Math.floor(Math.random() * chars.length))
  ).join("");

  logger.success(`🔐 Mot de passe généré (${length} chars)`);

  res.json({
    password,
    length,
    strength: password.length >= 16 ? "TRÈS FORT" : password.length >= 12 ? "FORT" : "MOYEN",
    includes_symbols: includeSymbols,
    timestamp: new Date().toISOString()
  });
});

// 📊 TEXT STATISTICS
router.post("/text-stats", (req, res) => {
  const { text } = req.body;

  if (!text) {
    return res.status(400).json({ error: "Texte requis" });
  }

  const words = text.trim().split(/\s+/).filter(w => w.length > 0);
  const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
  const lines = text.split("\n");
  const chars = text.length;
  const charsNoSpaces = text.replace(/\s/g, "").length;

  logger.naruto(`📊 Analysant texte (${chars} chars)`);

  res.json({
    characters: chars,
    characters_no_spaces: charsNoSpaces,
    words: words.length,
    sentences: sentences.length,
    lines: lines.length,
    paragraphs: text.split(/\n\n+/).filter(p => p.trim().length > 0).length,
    average_word_length: Math.round(charsNoSpaces / words.length || 0),
    average_sentence_length: Math.round(words.length / sentences.length || 0),
    most_common_word: getMostCommonWord(words),
    timestamp: new Date().toISOString()
  });
});

