// 🔐 HASH
router.get("/hash", (req, res) => {
  const text = req.query.text;
  const type = req.query.type || "sha256";

  if (!text) {
    return res.status(400).json({ error: "Texte requis" });
  }

  try {
    const hash = crypto.createHash(type).update(text).digest("hex");
    
    logger.success(`Hash ${type}: "${text.substring(0, 20)}..."`);
    
    res.json({
      text,
      type,
      hash,
      lengths: {
        original: text.length,
        hash: hash.length
      },
      algorithms: ["md5", "sha1", "sha256", "sha512"]
    });
  } catch (e) {
    logger.error(`Hash error: ${e.message}`);
    res.status(400).json({ error: "Algorithme invalide", message: e.message });
  }
});

