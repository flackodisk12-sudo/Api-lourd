// 📝 JSON FORMATTER
router.post("/json-format", (req, res) => {
  const { json, indent } = req.body;

  if (!json) {
    return res.status(400).json({ error: "JSON requis" });
  }

  try {
    const parsed = typeof json === "string" ? JSON.parse(json) : json;
    const formatted = JSON.stringify(parsed, null, indent || 2);
    const minified = JSON.stringify(parsed);

    logger.success(`JSON formaté (${formatted.length} chars)`);

    res.json({
      formatted,
      minified,
      valid: true,
      size: {
        formatted: formatted.length,
        minified: minified.length
      }
    });
  } catch (e) {
    logger.error(`JSON error: ${e.message}`);
    res.status(400).json({ error: "JSON invalide", message: e.message });
  }
});

// 🧮 CALCULATOR
router.get("/calculator", (req, res) => {
  const { a, b, op } = req.query;

  if (!a || !b || !op) {
    return res.status(400).json({
      error: "Paramètres requis: a, b, op (+, -, *, /, %)"
    });
  }

  const num1 = parseFloat(a);
  const num2 = parseFloat(b);

  if (isNaN(num1) || isNaN(num2)) {
    return res.status(400).json({ error: "a et b doivent être des nombres" });
  }

  let result;
  switch (op) {
    case "+":
      result = num1 + num2;
      break;
    case "-":
      result = num1 - num2;
      break;
    case "*":
      result = num1 * num2;
      break;
    case "/":
      if (num2 === 0) return res.status(400).json({ error: "Division par zéro!" });
      result = num1 / num2;
      break;
    case "%":
      result = num1 % num2;
      break;
    default:
      return res.status(400).json({ error: "Opération invalide" });
  }

  logger.info(`Calcul: ${num1} ${op} ${num2} = ${result}`);

  res.json({
    a: num1,
    b: num2,
    operation: op,
    result: Math.round(result * 10000) / 10000,
    timestamp: new Date().toISOString()
  });
});

// ⚡ HELPER: Most common word
function getMostCommonWord(words) {
  const frequency = {};
  words.forEach(word => {
    const lower = word.toLowerCase();
    frequency[lower] = (frequency[lower] || 0) + 1;
  });

  return Object.entries(frequency)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 5)
    .map(([word, count]) => ({ word, count }));
}

