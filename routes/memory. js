const express = require("express");
const fs = require("fs-extra");
const path = require("path");

const router = express.Router();

// 🌸 LOGGER
const logger = {
  info: (msg) => console.log("ℹ️  [MEMORY] " + msg),
  success: (msg) => console.log("✅ [MEMORY] " + msg),
  warn: (msg) => console.log("⚠️  [MEMORY] " + msg),
  error: (msg) => console.log("❌ [MEMORY] " + msg),
  naruto: (msg) => console.log("🍥 [MEMORY] " + msg)
};

const DB = path.join(__dirname, "../database/memory.json");
const BACKUP_DIR = path.join(__dirname, "../database/backups");

// 📁 ENSURE DIRS
fs.ensureDirSync(path.dirname(DB));
fs.ensureDirSync(BACKUP_DIR);

// 📦 LOAD DATABASE
function load() {
  try {
    if (!fs.existsSync(DB)) {
      logger.warn("Database not found, creating new one");
      return {};
    }
    return fs.readJSONSync(DB);
  } catch (e) {
    logger.error(`Load error: ${e.message}`);
    return {};
  }
}

// 💾 SAVE DATABASE
function save(data) {
  try {
    fs.writeJSONSync(DB, data, { spaces: 2 });
    logger.success("Database saved");
  } catch (e) {
    logger.error(`Save error: ${e.message}`);
  }
}

// 🔄 BACKUP DATABASE
function backup() {
  try {
    const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
    const backupPath = path.join(BACKUP_DIR, `memory_${timestamp}.json`);
    
    if (fs.existsSync(DB)) {
      fs.copySync(DB, backupPath);
      logger.success(`Backup créé: ${backupPath}`);
    }
  } catch (e) {
    logger.error(`Backup error: ${e.message}`);
  }
}

// 👤 GET USER MEMORY
router.get("/:id", (req, res) => {
  const db = load();
  const id = req.params.id.toLowerCase();

  logger.info(`📖 Récupérant mémoire pour: ${id}`);

  const user = db[id] || {
    id,
    name: null,
    messages: 0,
    created_at: new Date().toISOString(),
    last_seen: new Date().toISOString(),
    personality: "friendly",
    preferences: {},
    memories: []
  };

  res.json({
    success: true,
    user,
    memory_count: user.memories ? user.memories.length : 0
  });
});

// ✏️ SET/UPDATE USER MEMORY
router.post("/:id", (req, res) => {
  const db = load();
  const id = req.params.id.toLowerCase();
  const { name, personality, preferences, message } = req.body;

  logger.naruto(`📝 Mettant à jour mémoire: ${id}`);

  if (!db[id]) {
    db[id] = {
      id,
      name: name || "Unknown",
      messages: 0,
      created_at: new Date().toISOString(),
      last_seen: new Date().toISOString(),
      personality: personality || "friendly",
      preferences: preferences || {},
      memories: []
    };
  }

  // 🔄 UPDATE FIELDS
  if (name) db[id].name = name;
  if (personality) db[id].personality = personality;
  if (preferences) db[id].preferences = { ...db[id].preferences, ...preferences };
  if (message) {
    db[id].memories = db[id].memories || [];
    db[id].memories.push({
      text: message,
      timestamp: new Date().toISOString()
    });
  }

  db[id].messages = (db[id].messages || 0) + 1;
  db[id].last_seen = new Date().toISOString();

  save(db);

  res.json({
    success: true,
    user: db[id],
    message: `✅ Mémoire mise à jour pour ${id}`
  });
});

// 🧠 ADD MEMORY
router.post("/:id/memory", (req, res) => {
  const db = load();
  const id = req.params.id.toLowerCase();
  const { memory, category = "general" } = req.body;

  if (!memory) {
    return res.status(400).json({ error: "Memory text required" });
  }

  logger.naruto(`💭 Ajoutant mémoire pour: ${id}`);

  if (!db[id]) {
    db[id] = {
      id,
      name: "Unknown",
      messages: 0,
      created_at: new Date().toISOString(),
      last_seen: new Date().toISOString(),
      personality: "friendly",
      preferences: {},
      memories: []
    };
  }

  db[id].memories = db[id].memories || [];
  db[id].memories.push({
    text: memory,
    category,
    timestamp: new Date().toISOString()
  });

  db[id].last_seen = new Date().toISOString();

  save(db);

  res.json({
    success: true,
    memory_added: memory,
    total_memories: db[id].memories.length
  });
});

// 📖 GET ALL MEMORIES
router.get("/:id/memories", (req, res) => {
  const db = load();
  const id = req.params.id.toLowerCase();

  logger.info(`📚 Récupérant toutes les mémoires: ${id}`);

  const user = db[id];

  if (!user) {
    return res.status(404).json({
      error: "User not found",
      message: `🍥 ${id} n'a pas de mémoires! 🍥`
    });
  }

  const memories = user.memories || [];
  const grouped = memories.reduce((acc, mem) => {
    const cat = mem.category || "general";
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(mem);
    return acc;
  }, {});

  res.json({
    success: true,
    user_id: id,
    total_memories: memories.length,
    grouped_by_category: grouped,
    memories
  });
});

// 🗑️ DELETE MEMORY
router.delete("/:id/memory/:index", (req, res) => {
  const db = load();
  const id = req.params.id.toLowerCase();
  const index = parseInt(req.params.index);

  logger.warn(`🗑️ Supprimant mémoire ${index} pour: ${id}`);

  if (!db[id] || !db[id].memories || !db[id].memories[index]) {
    return res.status(404).json({ error: "Memory not found" });
  }

  const deleted = db[id].memories.splice(index, 1);
  save(db);

  res.json({
    success: true,
    deleted: deleted[0],
    remaining: db[id].memories.length
  });
});

// 🧹 CLEAR ALL MEMORIES
router.delete("/:id/memories", (req, res) => {
  const db = load();
  const id = req.params.id.toLowerCase();

  logger.warn(`🔥 Effaçant TOUTES les mémoires: ${id}`);

  if (!db[id]) {
    return res.status(404).json({ error: "User not found" });
  }

  const count = (db[id].memories || []).length;
  db[id].memories = [];

  save(db);

  res.json({
    success: true,
    message: `${count} mémoires supprimées`,
    user: db[id]
  });
});

// 👥 GET ALL USERS
router.get("/", (req, res) => {
  const db = load();

  logger.info(`👥 Récupérant tous les utilisateurs (${Object.keys(db).length})`);

  const stats = {
    total_users: Object.keys(db).length,
    total_memories: Object.values(db).reduce((sum, u) => sum + (u.memories ? u.memories.length : 0), 0),
    total_messages: Object.values(db).reduce((sum, u) => sum + (u.messages || 0), 0),
    users: Object.values(db).map(u => ({
      id: u.id,
      name: u.name,
      messages: u.messages,
      memories: (u.memories || []).length,
      personality: u.personality,
      last_seen: u.last_seen
    }))
  };

  res.json({
    success: true,
    ...stats
  });
});

// 🔄 SEARCH MEMORIES
router.get("/:id/search", (req, res) => {
  const db = load();
  const id = req.params.id.toLowerCase();
  const { query } = req.query;

  if (!query) {
    return res.status(400).json({ error: "Query required" });
  }

  logger.info(`🔍 Cherchant: "${query}" pour ${id}`);

  if (!db[id]) {
    return res.status(404).json({ error: "User not found" });
  }

  const results = (db[id].memories || []).filter(mem =>
    mem.text.toLowerCase().includes(query.toLowerCase())
  );

  res.json({
    success: true,
    query,
    results_count: results.length,
    results
  });
});

// 💾 BACKUP & RESTORE
router.post("/backup", (req, res) => {
  logger.naruto(`🔄 Créant backup...`);
  backup();

  res.json({
    success: true,
    message: "Backup créé avec succès!",
    backup_dir: BACKUP_DIR
  });
});

router.get("/backup/list", (req, res) => {
  logger.info(`📋 Listant les backups...`);

  const backups = fs.readdirSync(BACKUP_DIR)
    .filter(f => f.endsWith(".json"))
    .map(f => ({
      name: f,
      path: path.join(BACKUP_DIR, f),
      size: fs.statSync(path.join(BACKUP_DIR, f)).size
    }))
    .sort((a, b) => b.name.localeCompare(a.name));

  res.json({
    success: true,
    total_backups: backups.length,
    backups
  });
});

// 📊 STATS
router.get("/stats", (req, res) => {
  const db = load();

  logger.naruto(`📊 Générateur de statistiques...`);

  const stats = {
    total_users: Object.keys(db).length,
    total_memories: Object.values(db).reduce((sum, u) => sum + (u.memories ? u.memories.length : 0), 0),
    total_messages: Object.values(db).reduce((sum, u) => sum + (u.messages || 0), 0),
    personalities: {},
    memory_categories: {}
  };

  Object.values(db).forEach(user => {
    const pers = user.personality || "unknown";
    stats.personalities[pers] = (stats.personalities[pers] || 0) + 1;

    (user.memories || []).forEach(mem => {
      const cat = mem.category || "general";
      stats.memory_categories[cat] = (stats.memory_categories[cat] || 0) + 1;
    });
  });

  res.json({
    success: true,
    stats,
    timestamp: new Date().toISOString()
  });
});

